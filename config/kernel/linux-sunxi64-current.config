# OrionOS kernel config fragment — Allwinner H618 / sunxi64-current
# Drop this file in config/kernel/ and Armbian build picks it up automatically.
# Avoids the need for KERNEL_CONFIGURE=yes + manual menuconfig.
#
# Applied on top of the Armbian defconfig via scripts/config tool.
# Format: CONFIG_NAME=y|m|n  (one per line, comments with #)

# ── HID gamepads ──────────────────────────────────────────────────────────────
CONFIG_HID_NINTENDO=m       # Switch Pro Controller, Joy-Con (hid-nintendo)
CONFIG_NINTENDO_FF=y        # Rumble for Nintendo controllers
CONFIG_HID_SONY=m           # DualShock 3/4
CONFIG_HID_PLAYSTATION=m    # DualSense PS5 (future-proofing)
CONFIG_SONY_FF=y
CONFIG_HID_XPADNEO=m        # Xbox One/Series via Bluetooth (xpadneo-dkms alternative)

# ── Input ─────────────────────────────────────────────────────────────────────
CONFIG_INPUT_JOYDEV=m
CONFIG_INPUT_UINPUT=m       # Required by oga_events virtual device

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_NTFS3_FS=m           # Native NTFS3 read/write (kernel 5.15+)
CONFIG_NTFS3_LZX_XPRESS=y   # NTFS compression support
CONFIG_EXFAT_FS=m           # exFAT (kernel 5.7+)

# ── GPU — Panfrost / Mali G31 ─────────────────────────────────────────────────
CONFIG_DRM_PANFROST=m
CONFIG_DRM_SCHED=m
# Ensure DRM/KMS is enabled (usually is in Armbian, but make explicit)
CONFIG_DRM=y
CONFIG_DRM_FBDEV_EMULATION=y

# ── Memory ────────────────────────────────────────────────────────────────────
CONFIG_ZRAM=m               # zram block device for swap
CONFIG_ZRAM_DEF_COMP_ZSTD=y # Default zram compressor: zstd
CONFIG_CRYPTO_ZSTD=y
CONFIG_CRYPTO_LZ4=y         # Alternative compressor

# ── Thermal ───────────────────────────────────────────────────────────────────
CONFIG_THERMAL=y
CONFIG_THERMAL_GOV_STEP_WISE=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_THERMAL=y

# ── CPU frequency ─────────────────────────────────────────────────────────────
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=m   # keep as fallback

# ── Bluetooth ─────────────────────────────────────────────────────────────────
CONFIG_BT=m
CONFIG_BT_RFCOMM=m
CONFIG_BT_HIDP=m            # HID over Bluetooth (gamepads)
CONFIG_BT_HCIBTUSB=m        # USB Bluetooth adapters
CONFIG_BT_LE=y

# ── USB storage ───────────────────────────────────────────────────────────────
CONFIG_USB_STORAGE=m
CONFIG_USB_UAS=m            # USB Attached SCSI (faster USB3 drives)

# ── Network (keep for OTA / WiFi) ─────────────────────────────────────────────
CONFIG_CFG80211=m
CONFIG_MAC80211=m
# RTL8189 / RTL8723 (common on Orange Pi boards)
CONFIG_RTL8XXXU=m
CONFIG_RTL8189ES=m

# ── Disable unused ────────────────────────────────────────────────────────────
# Saves kernel size and reduces attack surface
CONFIG_SOUND_OSS_CORE=n    # OSS legacy sound — not needed with ALSA
CONFIG_FB_VIRTUAL=n        # Virtual framebuffer — not needed
