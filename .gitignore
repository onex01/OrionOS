# ═══════════════════════════════════════════════════════════════
# OrionOS .gitignore
# ═══════════════════════════════════════════════════════════════

# --- Бинарные ядра (скачиваются через sync-cores.sh) ---
src/overlay/opt/orionos/cores/*.so
src/overlay/opt/orionos/cores/*.zip

# --- Темы (скачиваются через sync-themes.sh) ---
src/overlay/opt/orionos/themes/*/
!src/overlay/opt/orionos/themes/.gitkeep

# --- Исходники (скачиваются через sync-resources.sh) ---
src/overlay/opt/orionos/sources/EmulationStation/
src/overlay/opt/orionos/sources/PortMaster-GUI/
src/overlay/opt/orionos/sources/es-theme-carbon/

# --- Armbian build system (~2-3 GB, клонируется при сборке) ---
armbian-build/

# --- Сборочные артефакты ---
*.img
*.img.tar.xz
*.img.gz
*.img.bz2
build/
dist/
output/images/

# --- Логи ---
*.log
/var/log/

# --- Кэши ---
*.cache
__pycache__/
*.pyc
*.pyo

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Временные файлы ---
tmp/
temp/
*.tmp
.history